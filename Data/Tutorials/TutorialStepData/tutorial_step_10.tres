[gd_resource type="Resource" script_class="TutorialStepData" format=3]

[ext_resource type="Script" path="res://Data/DataScript/TutorialStepData.cs" id="1_step"]

[resource]
script = ExtResource("1_step")
stepId = "tutorial_10_battle_log"
orderIndex = 10
title = "打开战斗记录"
promptText = "结算开始后，右上角的战斗记录会持续收集后台 CombatEvent 生成的行动、伤害、治疗、移动和战败信息。请点击它查看本回合发生了什么。\n遇到预期之外的情况，可以查看战斗记录与百科中的区域修正，了解发生了什么。"
promptHorizontalPosition = 2
highlightTarget = 9
waitCondition = 10
blocksOtherInput = true
